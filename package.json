{
  "name": "mermark",
  "private": true,
  "version": "0.8.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:browser": "vite --mode browser",
    "build": "tsc && vite build",
    "preview": "vite preview",
